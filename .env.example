# Copy to .env and fill in from Supabase dashboard: Project Settings -> API
# Use the BASE project URL (no /rest/v1/ suffix) and the anon/publishable key.
# The service_role key must NEVER appear in this project.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Push notifications (Phase 6 — optional). The PUBLIC VAPID key is frontend-safe.
# Generate a pair with:  npx web-push generate-vapid-keys
# The matching PRIVATE key is set ONLY as a Supabase Edge Function secret — never here.
VITE_VAPID_PUBLIC_KEY=
